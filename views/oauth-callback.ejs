<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Authenticating...</title>
    <style>
        body { background: #121212; color: #fff; font-family: sans-serif; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        .loader { width: 48px; height: 48px; border: 3px solid rgba(245, 175, 25, 0.1); border-top-color: #f5af19; border-radius: 50%; animation: spin 1s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="loader"></div>
    <script type="module">
        import { StackClientApp } from "https://esm.sh/@stackframe/js@2.8.78";
        const stack = new StackClientApp({
            projectId: "<%= stackProjectId %>",
            tokenStore: "cookie",
        });

        async function processOAuth() {
            try {
                // Call the stack SDK to complete the OAuth flow
                await stack.callOAuthCallback();
                
                // Get the returnUrl from session storage or default
                const returnTo = sessionStorage.getItem('stack_returnTo') || '/';
                window.location.href = returnTo;
            } catch (err) {
                console.error("OAuth callback failed:", err);
                document.body.innerHTML = '<h2>Authentication Failed</h2><p>Please <a href="/sign-in" style="color:#f5af19">try again</a>.</p>';
            }
        }
        processOAuth();
    </script>
</body>
</html>
