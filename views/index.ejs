<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Map</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <script src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'map-bg': '#121212',
                        'sidebar-bg': '#1e1e1e',
                        'loyal': '#f5af19',
                        'addiction': '#ff4b2b',
                    },
                },
            },
        }
    </script>
    <style>
        .sidebar { background-color: #1a1a1a; border-left: 1px solid #333; }
        .grid-bg { 
            background-color: #121212;
            background-image: 
                linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
            background-size: 40px 40px;
        }
        .node { 
            width: 64px; height: 64px; border-radius: 9999px; border: 2px solid #ccc; 
            overflow: hidden; cursor: pointer; transition: all 0.3s; position: relative;
        }
        .node:hover { border-color: #f5af19; transform: scale(1.1); z-index: 20; }
        .node-active { border-color: #f5af19; transform: scale(1.1); z-index: 30; }
        .custom-progress { height: 8px; width: 100%; background-color: #374151; border-radius: 9999px; overflow: hidden; }
        .progress-bar { height: 100%; transition: all 0.5s ease-in-out; }
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
    <script>
        let scale = 1;
        let pannedX = 0;
        let pannedY = 0;
        let isDragging = false;
        let hasMoved = false; // New flag for drag threshold
        const dragThreshold = 2; // More sensitive for mobile clicks
        let startX, startY;

        const inner = document.getElementById('map-inner');
        const container = document.getElementById('map-container');

        function updateTransform() {
            const inner = document.getElementById('map-inner');
            if (inner) {
                inner.style.transform = `translate(${pannedX}px, ${pannedY}px) scale(${scale})`;
            }
            
            const container = document.getElementById('map-container');
            if (container) {
                // Subtle parallax: background moves at 15% speed of nodes
                container.style.backgroundPosition = `${pannedX * 0.15}px ${pannedY * 0.15}px`;
                container.style.backgroundSize = `${40 * scale}px ${40 * scale}px`;
            }
            
            drawConnections();
        }

        /**
         * Zoom towards a focal point (fx, fy) in viewport coordinates.
         * If fx/fy are undefined, it zooms toward the container center.
         */
        function zoom(multiplier, fx, fy) {
            const container = document.getElementById('map-container');
            const rect = container.getBoundingClientRect();
            
            // Default to container center if no coordinates provided (e.g., from buttons)
            if (fx === undefined) fx = rect.left + rect.width / 2;
            if (fy === undefined) fy = rect.top + rect.height / 2;
            
            const oldScale = scale;
            scale = Math.min(Math.max(0.4, scale * multiplier), 3); // 3x cap for usability
            const ratio = scale / oldScale;
            
            // Map viewport coordinates (fx, fy) into local container space (relative to rect.left/top)
            // and keep that point stationary during scale change.
            pannedX = (fx - rect.left) - ((fx - rect.left) - pannedX) * ratio;
            pannedY = (fy - rect.top) - ((fy - rect.top) - pannedY) * ratio;
            
            updateTransform();
        }

        function resetView() {
            scale = 1;
            pannedX = 0;
            pannedY = 0;
            updateTransform();
        }

        function drawConnections() {
            const svg = document.getElementById('connections');
            const nodes = document.querySelectorAll('[id^="node-"]');
            if (!svg || nodes.length < 2) return;
            svg.innerHTML = '';
            
            // Draw a network-style path (sequential for now, but curved)
            for(let i=0; i<nodes.length-1; i++) {
                const n1 = nodes[i];
                const n2 = nodes[i+1];
                
                const x1 = n1.offsetLeft;
                const y1 = n1.offsetTop;
                const x2 = n2.offsetLeft;
                const y2 = n2.offsetTop;

                // Calculate control point for curve
                const midX = (x1 + x2) / 2;
                const midY = (y1 + y2) / 2;
                // Add some offset for the curve
                const cpX = midX + (y2 - y1) * 0.1;
                const cpY = midY - (x2 - x1) * 0.1;

                const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                const d = `M ${x1} ${y1} Q ${cpX} ${cpY} ${x2} ${y2}`;
                
                path.setAttribute('d', d);
                path.setAttribute('fill', 'none');
                path.setAttribute('stroke', 'rgba(255,255,255,0.1)');
                path.setAttribute('stroke-width', '1.5px');
                path.setAttribute('stroke-dasharray', '4 4'); // Modern dashed look
                svg.appendChild(path);
            }
        }

        function toggleSidebar(open) {
            const sidebar = document.getElementById('sidebar');
            const backdrop = document.getElementById('sidebar-backdrop');
            if (!sidebar) return;

            if (open) {
                // Ignore animation on Desktop because the sidebar is a persistent panel
                if (window.innerWidth >= 1024) return;
                
                // Use fromTo to strictly enforce the animation start values, bypassing Tailwind CSS transition conflicts
                gsap.fromTo(sidebar, 
                    { x: '100%' }, 
                    { 
                        x: '0%', 
                        duration: 0.4, 
                        ease: "power2.out",
                        onStart: () => sidebar.classList.remove('translate-x-full')
                    }
                );
                
                if (backdrop) {
                    backdrop.classList.remove('hidden');
                    gsap.to(backdrop, { opacity: 1, duration: 0.3 });
                }
            } else {
                // Remove active class from any node when sidebar closes / deselects
                document.querySelectorAll('.node-active').forEach(el => el.classList.remove('node-active'));
                
                // On Desktop, "closing" means clearing the selection
                if (window.innerWidth >= 1024) {
                    const sidebarContent = document.getElementById('sidebar-content');
                    if (sidebarContent) {
                        sidebarContent.innerHTML = '<div class="text-gray-500 italic text-center mt-20">Select a contact to view details</div>';
                    }
                    return;
                }
                
                gsap.to(sidebar, { 
                    x: '100%', 
                    duration: 0.3, 
                    ease: "power2.in",
                    onComplete: () => {
                        // For mobile we want to keep it translate-x-full for the initial state
                        sidebar.classList.add('translate-x-full');
                        // Reset GSAP transform so it doesn't conflict with Tailwind if resized
                        gsap.set(sidebar, { clearProps: "transform" });
                    }
                });
                if (backdrop) {
                    gsap.to(backdrop, { 
                        opacity: 0, 
                        duration: 0.3,
                        onComplete: () => backdrop.classList.add('hidden')
                    });
                }
            }
        }

        window.addEventListener('load', () => {
            const mapContainer = document.getElementById('map-container');
            
            // --- Wheel Zoom (Mouse) ---
            mapContainer.addEventListener('wheel', (e) => {
                e.preventDefault();
                const multiplier = e.deltaY > 0 ? 0.9 : 1.1; // 10% step
                // Pass viewport client coordinates directly to zoom function
                zoom(multiplier, e.clientX, e.clientY);
            }, { passive: false });

            // --- Mouse Events (Pan) ---
            mapContainer.addEventListener('mousedown', (e) => {
                isDragging = true;
                hasMoved = false;
                startX = e.clientX - pannedX;
                startY = e.clientY - pannedY;
            });

            window.addEventListener('mousemove', (e) => {
                if (!isDragging) return;
                const newX = e.clientX - startX;
                const newY = e.clientY - startY;

                if (Math.hypot(newX - pannedX, newY - pannedY) > dragThreshold) {
                    hasMoved = true;
                }

                pannedX = newX;
                pannedY = newY;
                updateTransform();
            });

            window.addEventListener('mouseup', (e) => { 
                isDragging = false; 
            });

            // --- Touch Events (Mobile/iPad Navigation & Zoom) ---
            let initialDistance = null;
            let initialScale = 1;
            let initialPannedX = 0;
            let initialPannedY = 0;
            let touchMidX, touchMidY;
            let touchStartX, touchStartY;

            mapContainer.addEventListener('touchstart', (e) => {
                if (e.touches.length === 1) {
                    isDragging = true;
                    hasMoved = false;
                    touchStartX = e.touches[0].clientX;
                    touchStartY = e.touches[0].clientY;
                    startX = e.touches[0].clientX - pannedX;
                    startY = e.touches[0].clientY - pannedY;
                } else if (e.touches.length === 2) {
                    isDragging = false;
                    initialDistance = Math.hypot(
                        e.touches[0].clientX - e.touches[1].clientX,
                        e.touches[0].clientY - e.touches[1].clientY
                    );
                    initialScale = scale;
                    initialPannedX = pannedX;
                    initialPannedY = pannedY;
                    touchMidX = (e.touches[0].clientX + e.touches[1].clientX) / 2;
                    touchMidY = (e.touches[0].clientY + e.touches[1].clientY) / 2;
                }
            }, { passive: false });

            mapContainer.addEventListener('touchmove', (e) => {
                if (e.touches.length === 1 && isDragging) {
                    const dx = e.touches[0].clientX - touchStartX;
                    const dy = e.touches[0].clientY - touchStartY;
                    
                    if (Math.hypot(dx, dy) > dragThreshold) {
                        e.preventDefault();
                        hasMoved = true;
                        pannedX = e.touches[0].clientX - startX;
                        pannedY = e.touches[0].clientY - startY;
                        updateTransform();
                    }
                } else if (e.touches.length === 2 && initialDistance) {
                    e.preventDefault();
                    hasMoved = true;
                    const currentDistance = Math.hypot(
                        e.touches[0].clientX - e.touches[1].clientX,
                        e.touches[0].clientY - e.touches[1].clientY
                    );
                    
                    // Focal point for pinch zoom is the midpoint between fingers
                    const midX = (e.touches[0].clientX + e.touches[1].clientX) / 2;
                    const midY = (e.touches[0].clientY + e.touches[1].clientY) / 2;
                    
                    const multiplier = currentDistance / initialDistance;
                    // Apply relative multiplier for flawless pinch zooming
                    zoom(multiplier, midX, midY); 
                    
                    // Reset initial distance for next movement to keep it smooth
                    initialDistance = currentDistance;
                }
            }, { passive: false });

            mapContainer.addEventListener('touchend', (e) => {
                if (e.touches.length === 0) {
                    isDragging = false;
                    // Extreme micro-delay to allow the click event to fire before hasMoved resets
                    setTimeout(() => { hasMoved = false; }, 10); 
                }
            });

            // Background click to close sidebar
            mapContainer.addEventListener('click', (e) => {
                const nodeContainer = e.target.closest('[id^="node-"]');
                if (!nodeContainer && !hasMoved) {
                    toggleSidebar(false);
                }
            });

            // Prevent HTMX request if we dragged and handle active states
            document.body.addEventListener('htmx:beforeRequest', (e) => {
                const nodeContainer = e.detail.elt.closest('[id^="node-"]');
                if (nodeContainer) {
                    if (hasMoved) {
                        e.preventDefault();
                        return;
                    }
                    
                    const innerNode = nodeContainer.querySelector('.node');
                    const sidebar = document.getElementById('sidebar');
                    const isSidebarOpen = sidebar && !sidebar.classList.contains('translate-x-full');
                    
                    if (innerNode && innerNode.classList.contains('node-active') && isSidebarOpen) {
                        e.preventDefault();
                        toggleSidebar(false);
                    } else {
                        document.querySelectorAll('.node-active').forEach(el => el.classList.remove('node-active'));
                        if (innerNode) {
                            innerNode.classList.add('node-active');
                        }
                        toggleSidebar(true);
                    }
                }
            });

            drawConnections();

            // Premium Lenis Horizontal Scroll Setup
            const navWrapper = document.getElementById('location-nav-wrapper');
            const navContent = document.getElementById('location-nav-content');
            
            if (navWrapper && navContent) {
                navWrapper.style.scrollBehavior = 'auto'; 
                window.lenisNav = new Lenis({
                    wrapper: navWrapper,
                    content: navContent,
                    orientation: 'horizontal',
                    gestureOrientation: 'both',
                    smoothWheel: true,
                    wheelMultiplier: 1.2,
                    touchMultiplier: 2,
                    infinite: false,
                });
                gsap.ticker.add((time) => {
                    window.lenisNav.raf(time * 1000);
                });
                gsap.ticker.lagSmoothing(0);
                scrollToActiveNav(true);
            }
        });

        function scrollToActiveNav(immediate = false) {
            if(!window.lenisNav) return;
            const activeItem = document.querySelector('#location-nav-inner .text-white');
            if (activeItem) {
                setTimeout(() => {
                    window.lenisNav.scrollTo(activeItem, {
                        offset: window.innerWidth < 1024 ? 0 : -50,
                        duration: immediate ? 0 : 1.2,
                        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
                        lock: true
                    });
                }, 50);
            }
        }

        document.body.addEventListener('htmx:afterSettle', function() {
            scrollToActiveNav(false);
        });

        document.body.addEventListener('htmx:afterSwap', function(evt) {
            if (evt.detail.target.id === 'sidebar-content') {
                toggleSidebar(true);
            }
        });

        window.addEventListener('resize', drawConnections);
    </script>
</head>
<body class="bg-[#121212] text-white h-screen overflow-hidden flex flex-col">
    <!-- Header -->
    <header class="h-14 flex shrink-0 border-b border-[#333]">
        <!-- Map Header Side -->
        <div class="flex-1 flex items-center pl-4 lg:px-6 overflow-hidden relative">
            <h1 class="text-lg lg:text-xl font-bold tracking-tight shrink-0 mr-4 lg:mr-8 hidden sm:block z-10 bg-[#121212]">CONTACT MAP</h1>
            <h1 class="text-lg font-bold tracking-tight shrink-0 mr-2 sm:hidden z-10 bg-[#121212] pr-2">MAP</h1>
            
            <div id="location-nav-wrapper" class="flex-1 overflow-x-auto overflow-y-hidden whitespace-nowrap scrollbar-hide h-full snap-x snap-mandatory">
                <div id="location-nav-content" class="h-full flex items-center min-w-full">
                    <%- include('partials/location-nav', { selectedLocation: selectedLocation, locations: locations }) %>
                </div>
            </div>
            
            <!-- Fade for visual depth on scroll -->
            <div class="absolute right-0 top-0 bottom-0 w-12 bg-gradient-to-l from-[#121212] to-transparent pointer-events-none lg:hidden z-10"></div>
        </div>

        <!-- Sidebar Header Side -->
        <div class="w-auto lg:w-80 sidebar shrink-0 flex items-center px-4 lg:px-6">
            <button onclick="document.getElementById('add-modal').classList.remove('hidden')" class="w-full py-1.5 bg-white text-black text-sm font-bold tracking-wide rounded hover:bg-gray-200 transition-colors">
                + ADD CLIENT
            </button>
        </div>
    </header>

    <main class="flex-1 flex overflow-hidden">
        <!-- Map Area -->
        <div class="flex-1 relative overflow-hidden grid-bg cursor-grab active:cursor-grabbing" id="map-container">
            
            <!-- Location HUD -->
            <div id="location-hud" class="absolute top-6 left-6 z-40 bg-[#1a1a1a] p-1 border border-gray-700 shadow-2xl hidden sm:block rounded-sm pointer-events-none transition-opacity duration-300" style="width: 240px; height: 135px;">
                <% if (typeof locationImage !== 'undefined' && locationImage) { %>
                    <img src="<%= locationImage %>" class="w-full h-full object-cover rounded-sm border border-[#333]">
                <% } else { %>
                    <div class="w-full h-full bg-gray-800 flex items-center justify-center text-gray-500 rounded-sm italic text-sm border border-[#333]">No Image</div>
                <% } %>
                <div class="absolute bottom-2 left-2 right-0 flex justify-start items-end">
                   <span class="bg-black/80 px-2 py-0.5 text-xs font-bold text-white uppercase tracking-wider rounded backdrop-blur-sm shadow-md"><%= selectedLocation %></span>
                </div>
            </div>

            <div id="map-inner" class="absolute inset-0 transition-transform duration-75 origin-top-left">
                <div id="map-content" class="w-full h-full">
                    <%- include('partials/map-content') %>
                </div>
            </div>
            
            <!-- Zoom Controls -->
            <div class="absolute bottom-6 left-6 flex flex-col gap-2 z-40">
                <button onclick="zoom(1.2)" class="w-10 h-10 bg-sidebar-bg border border-gray-700 rounded hover:bg-gray-800 transition-colors flex items-center justify-center text-xl font-bold">+</button>
                <button onclick="zoom(0.833)" class="w-10 h-10 bg-sidebar-bg border border-gray-700 rounded hover:bg-gray-800 transition-colors flex items-center justify-center text-xl font-bold">−</button>
                <button onclick="resetView()" class="w-10 h-10 bg-sidebar-bg border border-gray-700 rounded hover:bg-gray-800 transition-colors flex items-center justify-center text-xs font-bold">1:1</button>
            </div>
        </div>

        <!-- Sidebar Backdrop (Mobile/iPad) -->
        <div id="sidebar-backdrop" class="hidden fixed inset-0 bg-black/50 z-30 lg:hidden backdrop-blur-sm transition-opacity duration-300" onclick="toggleSidebar(false)"></div>

        <!-- Sidebar -->
        <aside class="fixed top-14 bottom-0 right-0 z-40 w-[90vw] sm:w-80 lg:w-80 sidebar flex flex-col transform translate-x-full lg:translate-x-0 lg:relative lg:top-auto shadow-2xl lg:shadow-none bg-[#1a1a1a]" id="sidebar">
            <div id="sidebar-content" class="p-6 h-full overflow-y-auto">
                <button onclick="toggleSidebar(false)" class="absolute top-4 right-4 lg:hidden text-gray-500 hover:text-white p-2">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
                <div class="text-gray-500 italic text-center mt-20">Select a contact to view details</div>
            </div>
        </aside>
    </main>

    <!-- Add Client Modal -->
    <div id="add-modal" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center z-50">
        <div class="bg-sidebar-bg p-8 rounded-lg w-full max-w-md border border-gray-700 shadow-2xl">
            <h2 class="text-2xl font-bold mb-6">NEW CONTACT</h2>
            <form action="/add-client" method="POST" enctype="multipart/form-data" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Name</label>
                    <input type="text" name="name" required class="w-full bg-[#121212] border border-gray-700 rounded px-3 py-2 focus:border-loyal outline-none">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Role</label>
                    <input type="text" name="role" placeholder="e.g. Customer" class="w-full bg-[#121212] border border-gray-700 rounded px-3 py-2 outline-none">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Avatar Image</label>
                    <input type="file" name="avatar" class="w-full text-sm text-gray-400">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Location</label>
                    <input list="locations-list" name="location" required placeholder="Select or enter new location..." class="w-full bg-[#121212] border border-gray-700 rounded px-3 py-2 outline-none focus:border-loyal text-sm text-gray-300">
                    <datalist id="locations-list">
                        <% locations.forEach(loc => { %>
                            <option value="<%- loc %>"></option>
                        <% }) %>
                    </datalist>
                </div>
                <div class="flex gap-4 pt-4">
                    <button type="button" onclick="document.getElementById('add-modal').classList.add('hidden')" class="flex-1 px-4 py-2 border border-gray-700 rounded hover:bg-gray-800 transition-colors">CANCEL</button>
                    <button type="submit" class="flex-1 px-4 py-2 bg-loyal text-black font-bold rounded hover:opacity-90 transition-colors">CREATE</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
